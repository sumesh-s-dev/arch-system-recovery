#!/usr/bin/env bash
# bin/arch-recovery — Arch System Recovery Toolkit
# Works when called from bash, zsh, fish (arch-recovery.fish), sh (arch-recovery.sh)
# https://github.com/sumesh-s-dev/arch-system-recovery
set -euo pipefail

# ── Require Bash 4.2+ ─────────────────────────────────────────────────────────
if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 2) )); then
    echo "ERROR: arch-recovery requires Bash 4.2 or newer." >&2
    echo "       Your version: ${BASH_VERSION}" >&2
    exit 1
fi

# ── Locate repository root ────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
LIB_DIR="${REPO_ROOT}/lib"

# ── Load modules ──────────────────────────────────────────────────────────────
for _module in core ui tui detect luks mount repair preflight diagnose \
               fstab pacman network snapshot health; do
    # shellcheck source=/dev/null
    source "${LIB_DIR}/${_module}.sh" || {
        echo "ERROR: failed to load module: ${_module}.sh" >&2; exit 1
    }
done
unset _module

# ── Runtime defaults ──────────────────────────────────────────────────────────
AUTO_MODE=false
DRY_RUN=false
TUI_MODE=false
DIAGNOSE_MODE=false
ROOT_DEVICE=""
EFI_DEVICE=""
LOG_LEVEL="normal"      # silent | normal | verbose | debug
DO_INITRAMFS=true
DO_BOOTLOADER=true
DO_FSTAB=true
DO_KEYRING=false
DO_NETWORK=false
LIST_SNAPSHOTS=false
SNAPSHOT_ROLLBACK=""
DO_HEALTH_CHECK=false
HEALTH_CHECK_ONLY=false
DO_UPDATE=false
CHECK_UPDATE_ONLY=false

# ── Safety trap ───────────────────────────────────────────────────────────────
_on_exit() {
    local code=$?
    [[ ${code} -eq 0 ]] || {
        declare -f err &>/dev/null \
            && err "Exiting with code ${code} — running cleanup..." \
            || echo "ERROR: Exiting with code ${code}" >&2
    }
    if declare -f cleanup_mounts &>/dev/null && [[ "${DRY_RUN}" != "true" ]]; then
        cleanup_mounts 2>/dev/null || true
    fi
    rm -f "/tmp/arch-recovery-preflight-$$.txt" 2>/dev/null || true
}
trap '_on_exit' EXIT
trap 'echo ""; echo "Interrupted — cleaning up..."; exit 130' INT TERM

# ── Argument parser ───────────────────────────────────────────────────────────
parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --auto)            AUTO_MODE=true; HEALTH_CHECK_ONLY=false; shift ;;
            --dry-run)         DRY_RUN=true;                shift ;;
            --tui)             TUI_MODE=true; HEALTH_CHECK_ONLY=false; shift ;;
            --diagnose)        DIAGNOSE_MODE=true; HEALTH_CHECK_ONLY=false; shift ;;
            --root)            ROOT_DEVICE="${2:?--root requires a device}"; shift 2 ;;
            --efi)             EFI_DEVICE="${2:?--efi requires a device}";   shift 2 ;;
            --no-initramfs)    DO_INITRAMFS=false; HEALTH_CHECK_ONLY=false; shift ;;
            --no-bootloader)   DO_BOOTLOADER=false; HEALTH_CHECK_ONLY=false; shift ;;
            --no-fstab)        DO_FSTAB=false; HEALTH_CHECK_ONLY=false; shift ;;
            --repair-keyring)  DO_KEYRING=true; HEALTH_CHECK_ONLY=false; shift ;;
            --setup-network)   DO_NETWORK=true; HEALTH_CHECK_ONLY=false; shift ;;
            --list-snapshots)  LIST_SNAPSHOTS=true; HEALTH_CHECK_ONLY=false; shift ;;
            --rollback)        SNAPSHOT_ROLLBACK="${2:?--rollback requires a snapshot name}"; HEALTH_CHECK_ONLY=false; shift 2 ;;
            --log-level)
                case "${2:-}" in
                    silent|normal|verbose|debug) LOG_LEVEL="$2" ;;
                    *) die "Unknown log level '${2:-}'. Use: silent|normal|verbose|debug" ;;
                esac
                shift 2 ;;
            --verbose|-v)      LOG_LEVEL="verbose";         shift ;;
            --debug)           LOG_LEVEL="debug";           shift ;;
            --silent|-q)       LOG_LEVEL="silent";          shift ;;
            --help|-h)         _show_help;  exit 0 ;;
            --version)         echo "arch-recovery ${TOOLKIT_VERSION}"; exit 0 ;;
            --changelog)       _show_changelog; exit 0 ;;
            --health-check)    DO_HEALTH_CHECK=true; HEALTH_CHECK_ONLY=true; shift ;;
            --update)          DO_UPDATE=true; HEALTH_CHECK_ONLY=false; shift ;;
            --check-update)    CHECK_UPDATE_ONLY=true; HEALTH_CHECK_ONLY=false; shift ;;
            *)
                err "Unknown option: $1"
                echo "  Run: sudo arch-recovery --help" >&2
                exit 1 ;;
        esac
    done
}

_show_help() {
cat <<EOF

$(printf '\033[1m')arch-recovery v${TOOLKIT_VERSION}$(printf '\033[0m') — Arch Linux System Recovery Toolkit

$(printf '\033[1m')USAGE$(printf '\033[0m')
    sudo arch-recovery [OPTIONS]

$(printf '\033[1m')MODES$(printf '\033[0m')
    (none)              Guided interactive mode  ← safest for beginners
    --tui               Full-screen menu (whiptail/dialog or built-in fallback)
    --auto              Fully automated, no prompts
    --diagnose          Scan and report only — makes zero changes
    --dry-run           Simulate everything; nothing written to disk

$(printf '\033[1m')DEVICES$(printf '\033[0m')
    --root <dev>        Root partition  e.g. /dev/sda2  /dev/nvme0n1p2
    --efi  <dev>        EFI  partition  e.g. /dev/sda1  /dev/nvme0n1p1

$(printf '\033[1m')REPAIRS$(printf '\033[0m') (all on by default unless opted out)
    --no-initramfs      Skip mkinitcpio rebuild
    --no-bootloader     Skip bootloader reinstall
    --no-fstab          Skip fstab validation / repair
    --repair-keyring    Also repair pacman keyring + refresh mirrorlist
    --setup-network     Set up network first (WiFi or ethernet)

$(printf '\033[1m')BTRFS SNAPSHOTS$(printf '\033[0m')
    --list-snapshots    List BTRFS snapshots on root device
    --rollback <name>   Roll back to a named BTRFS snapshot

$(printf '\033[1m')POST-REPAIR$(printf '\033[0m')
    --health-check      Verify system is ready to boot (no changes)

$(printf '\033[1m')SELF-UPDATE$(printf '\033[0m')
    --update            Download and install latest release from GitHub
    --check-update      Check if a newer release exists (no install)

$(printf '\033[1m')VERBOSITY$(printf '\033[0m')
    --verbose / -v      Extra detail
    --debug             Trace every command
    --silent / -q       Errors only
    --log-level <lvl>   silent | normal | verbose | debug

$(printf '\033[1m')SHELL LAUNCHERS$(printf '\033[0m')
    arch-recovery           bash / zsh (default)
    arch-recovery.fish      fish shell
    arch-recovery.sh        POSIX sh / dash

$(printf '\033[1m')LOG$(printf '\033[0m')
    ${LOG_FILE}

$(printf '\033[1m')EXAMPLES$(printf '\033[0m')
    sudo arch-recovery                              # guided (beginner-friendly)
    sudo arch-recovery --tui                        # full-screen menu
    sudo arch-recovery --diagnose                   # what's broken?
    sudo arch-recovery --auto                       # fix everything automatically
    sudo arch-recovery --dry-run --verbose          # preview in full detail
    sudo arch-recovery --root /dev/sda2 --efi /dev/sda1
    sudo arch-recovery --auto --repair-keyring
    sudo arch-recovery --list-snapshots --root /dev/sda2
    sudo arch-recovery --rollback @2024-01-15 --root /dev/sda2
    sudo arch-recovery --no-bootloader --repair-keyring --auto

EOF
}

_show_changelog() {
    cat <<'EOF'
CHANGELOG

v1.1.0
  + TUI full-screen menu (--tui) with whiptail/dialog, pure-bash fallback
  + Diagnose mode: colour-coded problem report, no changes (--diagnose)
  + Pre-flight checks: disk space, kernel presence, locale, missing hooks
  + fstab validator and auto-fixer (--no-fstab to skip)
  + Pacman keyring + mirrorlist repair (--repair-keyring)
  + Network setup from live USB: ethernet + nmcli WiFi (--setup-network)
  + BTRFS snapshot listing and rollback (--list-snapshots, --rollback)
  + Fish shell launcher: bin/arch-recovery.fish
  + POSIX sh launcher:   bin/arch-recovery.sh
  + Selective repair flags (--no-initramfs, --no-bootloader, --no-fstab)
  + Log levels: silent/normal/verbose/debug
  + LVM volume group detection and activation
  + Per-step rollback plan written to log before every destructive action
  + Colour-coded output with TTY detection (no colour when piped)

v1.0.0
  + Initial release
  + BTRFS / ext4, LUKS, GRUB (UEFI), systemd-boot
EOF
}

# ── Main orchestration ────────────────────────────────────────────────────────
main() {
    parse_args "$@"

    init_log
    export LOG_LEVEL

    # Self-update / check-update
    if ${CHECK_UPDATE_ONLY}; then
        _check_for_update
        return 0
    fi
    if ${DO_UPDATE}; then
        _self_update
        return 0
    fi

    # Hand off to TUI immediately if requested
    if ${TUI_MODE}; then
        tui_main
        return 0
    fi

    print_banner
    check_root

    dlog "Repository root : ${REPO_ROOT}"
    dlog "Log level       : ${LOG_LEVEL}"
    dlog "Bash version    : ${BASH_VERSION}"

    # ── Standalone health check ───────────────────────────────────────────────
    if ${HEALTH_CHECK_ONLY}; then
        check_deps "readonly"
        run_standalone_health_check "${ROOT_DEVICE}" "${EFI_DEVICE}"
        return 0
    fi

    # ── Diagnose only ─────────────────────────────────────────────────────────
    if ${DIAGNOSE_MODE}; then
        check_deps "readonly"
        diagnose_main "${ROOT_DEVICE}" "${EFI_DEVICE}"
        return 0
    fi

    # ── Snapshot list ─────────────────────────────────────────────────────────
    if ${LIST_SNAPSHOTS}; then
        check_deps "readonly"
        [[ -z "${ROOT_DEVICE}" ]] && ROOT_DEVICE="$(
            ${AUTO_MODE} && auto_detect_root || prompt_root_device)"
        MAPPED_ROOT="${ROOT_DEVICE}"
        if is_luks "${ROOT_DEVICE}"; then
            log "LUKS detected on ${ROOT_DEVICE}"
            MAPPED_ROOT="$(unlock_luks "${ROOT_DEVICE}")"
        fi
        MAPPED_ROOT="$(detect_lvm "${MAPPED_ROOT}")"
        list_btrfs_snapshots "${MAPPED_ROOT}"
        return 0
    fi

    if [[ -n "${SNAPSHOT_ROLLBACK}" ]]; then
        check_deps "readonly"
    else
        check_deps
    fi

    # ── Network ───────────────────────────────────────────────────────────────
    if ${DO_NETWORK}; then
        print_step "NET" "Network setup"
        setup_network
    fi

    # ── Root partition ────────────────────────────────────────────────────────
    print_step "1" "Identify root partition"
    if [[ -z "${ROOT_DEVICE}" ]]; then
        ROOT_DEVICE="$(${AUTO_MODE} && auto_detect_root || prompt_root_device)"
    fi
    log "Root device     : ${ROOT_DEVICE}"

    # ── LUKS ──────────────────────────────────────────────────────────────────
    print_step "2" "Encryption check"
    MAPPED_ROOT="${ROOT_DEVICE}"
    if is_luks "${ROOT_DEVICE}"; then
        log "LUKS detected on ${ROOT_DEVICE}"
        MAPPED_ROOT="$(unlock_luks "${ROOT_DEVICE}")"
    else
        log "No LUKS encryption on ${ROOT_DEVICE}"
    fi

    # ── LVM ───────────────────────────────────────────────────────────────────
    MAPPED_ROOT="$(detect_lvm "${MAPPED_ROOT}")"

    # ── Filesystem ───────────────────────────────────────────────────────────
    print_step "3" "Filesystem detection"
    FS_TYPE="$(detect_filesystem "${MAPPED_ROOT}")"

    # ── Snapshot rollback ─────────────────────────────────────────────────────
    if [[ -n "${SNAPSHOT_ROLLBACK}" ]]; then
        if ${DRY_RUN}; then
            log "[dry-run] Would roll back ${MAPPED_ROOT} to snapshot ${SNAPSHOT_ROLLBACK}"
            return 0
        fi
        if ! ${AUTO_MODE}; then
            confirm_snapshot_rollback "${ROOT_DEVICE}" "${MAPPED_ROOT}" "${SNAPSHOT_ROLLBACK}"
        fi
        _save_snapshot_rollback_plan "${ROOT_DEVICE}" "${MAPPED_ROOT}" "${SNAPSHOT_ROLLBACK}"
        rollback_snapshot "${MAPPED_ROOT}" "${SNAPSHOT_ROLLBACK}"
        return 0
    fi

    # ── Mount root ────────────────────────────────────────────────────────────
    print_step "4" "Mount root filesystem"
    if ${DRY_RUN}; then
        log "[dry-run] Would mount ${MAPPED_ROOT} (${FS_TYPE}) at ${MOUNT_ROOT}"
    else
        mount_root "${MAPPED_ROOT}" "${FS_TYPE}"
    fi

    # ── EFI ───────────────────────────────────────────────────────────────────
    print_step "5" "EFI partition"
    if [[ -z "${EFI_DEVICE}" ]]; then
        EFI_DEVICE="$(${AUTO_MODE} && auto_detect_efi || prompt_efi_device)"
    fi
    if [[ -n "${EFI_DEVICE}" ]]; then
        ${DRY_RUN} && log "[dry-run] Would mount EFI ${EFI_DEVICE}" \
                   || mount_efi "${EFI_DEVICE}"
    fi

    # ── Bootloader detection ─────────────────────────────────────────────────
    print_step "6" "Detect bootloader"
    BOOTLOADER="$(detect_bootloader)"

    # ── Pre-flight ────────────────────────────────────────────────────────────
    print_step "7" "Pre-flight checks"
    run_preflight "${MAPPED_ROOT}" "${EFI_DEVICE:-}" "${FS_TYPE}"

    # ── fstab validation ──────────────────────────────────────────────────────
    if ${DO_FSTAB} && ! ${DRY_RUN}; then
        print_step "8" "Validate /etc/fstab"
        validate_and_repair_fstab
    fi

    # ── Confirm before destructive steps ──────────────────────────────────────
    if ! ${AUTO_MODE} && ! ${DRY_RUN}; then
        confirm_repair \
            "${ROOT_DEVICE}" "${EFI_DEVICE:-none}" "${FS_TYPE}" \
            "${BOOTLOADER}" "${DO_INITRAMFS}" "${DO_BOOTLOADER}" \
            "${DO_FSTAB}" "${DO_KEYRING}"
    fi

    # Save rollback plan to log before touching anything
    _save_rollback_plan "${ROOT_DEVICE}" "${EFI_DEVICE:-}" "${BOOTLOADER}"

    # ── Pacman keyring ────────────────────────────────────────────────────────
    if ${DO_KEYRING} && ! ${DRY_RUN}; then
        print_step "9" "Repair pacman keyring"
        repair_pacman_keyring
    fi

    # ── initramfs ─────────────────────────────────────────────────────────────
    if ${DO_INITRAMFS}; then
        print_step "10" "Rebuild initramfs"
        ${DRY_RUN} && log "[dry-run] arch-chroot mkinitcpio -P" \
                   || repair_initramfs
    fi

    # ── Bootloader ────────────────────────────────────────────────────────────
    if ${DO_BOOTLOADER}; then
        print_step "11" "Repair bootloader: ${BOOTLOADER}"
        ${DRY_RUN} && log "[dry-run] reinstall ${BOOTLOADER}" \
                   || repair_bootloader "${BOOTLOADER}" "${EFI_DEVICE:-}"
    fi

    # ── Post-repair health check ─────────────────────────────────────────────
    if ${DO_HEALTH_CHECK} && ! ${DRY_RUN}; then
        print_step "12" "Post-repair health check"
        run_health_check
    fi

    # ── Cleanup ───────────────────────────────────────────────────────────────
    ${DRY_RUN} || cleanup_mounts

    log "═══════════════════════════════════════════════"
    log " Recovery complete"
    log " Full log: ${LOG_FILE}"
    log "═══════════════════════════════════════════════"
    echo ""
    _c_green; _c_bold
    printf "  ✓  Recovery complete — safe to reboot.\n"
    _c_reset
    printf "     Full log: %s\n\n" "${LOG_FILE}"
}

# ── Save rollback plan ────────────────────────────────────────────────────────
_save_rollback_plan() {
    local root="$1" efi="${2:-}" bl="${3:-}"
    {
        echo "═══ ROLLBACK PLAN (generated $(date)) ═══"
        echo "If this recovery made things worse, here is how to undo it manually:"
        echo ""
        echo "1. Boot the Arch live ISO again."
        echo "2. If LUKS: cryptsetup open ${root} recovery_crypt"
        echo "3. Mount root: mount ${root} /mnt"
        [[ -n "${efi}" ]] && echo "4. Mount EFI: mount ${efi} /mnt/boot/efi"
        echo "5. arch-chroot /mnt"
        echo "6. To redo initramfs: mkinitcpio -P"
        case "${bl}" in
            grub)
                echo "7. To redo GRUB: grub-install --target=x86_64-efi --efi-directory=/boot/efi"
                echo "                  grub-mkconfig -o /boot/grub/grub.cfg" ;;
            systemd-boot)
                echo "7. To redo systemd-boot: bootctl install" ;;
        esac
        echo "═══════════════════════════════════════════"
    } >> "${LOG_FILE}"
    dlog "Rollback plan saved to ${LOG_FILE}"
}

_save_snapshot_rollback_plan() {
    local root="$1" mapped_root="$2" snapshot="$3"
    {
        echo "═══ SNAPSHOT ROLLBACK PLAN (generated $(date)) ═══"
        echo "Target snapshot : ${snapshot}"
        echo "Mapped root     : ${mapped_root}"
        echo ""
        echo "If rollback fails or boots badly:"
        echo "1. Boot the Arch live ISO again."
        [[ "${root}" != "${mapped_root}" ]] && \
            echo "2. Re-open the original root container: ${root}"
        echo "3. Mount top-level BTRFS: mount -o subvolid=5 ${mapped_root} /mnt/top"
        echo "4. Rename ${snapshot} rollback target or restore the preserved @.broken-* subvolume."
        echo "5. Unmount: umount /mnt/top"
        echo "═══════════════════════════════════════════════════"
    } >> "${LOG_FILE}"
    dlog "Snapshot rollback plan saved to ${LOG_FILE}"
}

run_standalone_health_check() {
    local root_dev="${1:-}"
    local efi_dev="${2:-}"
    local mapped_root fstype

    print_step "HC1" "Identify root partition"
    if [[ -z "${root_dev}" ]]; then
        root_dev="$(auto_detect_root 2>/dev/null || prompt_root_device)"
    fi
    log "Health-check root device: ${root_dev}"

    mapped_root="${root_dev}"
    if is_luks "${root_dev}"; then
        log "LUKS detected on ${root_dev}"
        mapped_root="$(unlock_luks "${root_dev}")"
    fi
    mapped_root="$(detect_lvm "${mapped_root}")"

    print_step "HC2" "Filesystem detection"
    fstype="$(detect_filesystem "${mapped_root}")"

    print_step "HC3" "Mount root filesystem (read-only)"
    mount_root "${mapped_root}" "${fstype}" ro

    if [[ -z "${efi_dev}" ]]; then
        efi_dev="$(auto_detect_efi 2>/dev/null || true)"
    fi
    if [[ -n "${efi_dev}" ]]; then
        print_step "HC4" "Mount EFI partition (read-only)"
        mount_efi "${efi_dev}" ro
    fi

    print_step "HC5" "Run health check"
    run_health_check
}

# ── Self-update helpers ───────────────────────────────────────────────────────

GITHUB_REPO="sumesh-s-dev/arch-system-recovery"
GITHUB_API="https://api.github.com/repos/${GITHUB_REPO}/releases/latest"

_check_for_update() {
    log "Checking for updates..."
    if ! command -v curl &>/dev/null; then
        die "--check-update requires curl. Install it: pacman -S curl"
    fi

    local latest_tag
    latest_tag="$(curl -fsSL "${GITHUB_API}" 2>/dev/null \
        | grep '"tag_name"' \
        | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')" \
        || die "Could not reach GitHub API. Check network connectivity."

    if [[ -z "${latest_tag}" ]]; then
        warn "Could not determine latest release tag."
        return 1
    fi

    local current="v${TOOLKIT_VERSION}"
    log "Current version : ${current}"
    log "Latest release  : ${latest_tag}"

    if [[ "${current}" == "${latest_tag}" ]]; then
        _c_green; printf "\n  ✓  arch-recovery is up to date (%s)\n\n" "${current}" >&2
        _c_reset
    else
        _c_yellow; _c_bold
        printf "\n  ↑  Update available: %s → %s\n" "${current}" "${latest_tag}" >&2
        _c_reset
        printf "     Run: sudo arch-recovery --update\n\n" >&2
    fi
}

_self_update() {
    _check_for_update

    local latest_tag
    latest_tag="$(curl -fsSL "${GITHUB_API}" 2>/dev/null \
        | grep '"tag_name"' \
        | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')"

    local current="v${TOOLKIT_VERSION}"
    [[ "${current}" == "${latest_tag}" ]] && {
        echo "  Already at latest version (${current})." >&2
        return 0
    }

    log "Downloading ${latest_tag}..."
    local tmpdir
    tmpdir="$(mktemp -d /tmp/arch-recovery-update.XXXXXX)"

    local tarball_url
    tarball_url="https://github.com/${GITHUB_REPO}/archive/refs/tags/${latest_tag}.tar.gz"

    curl -fsSL "${tarball_url}" -o "${tmpdir}/release.tar.gz" \
        || die "Failed to download release tarball from ${tarball_url}"

    tar -xzf "${tmpdir}/release.tar.gz" -C "${tmpdir}" \
        || die "Failed to extract release tarball"

    local extracted_dir
    extracted_dir="$(find "${tmpdir}" -maxdepth 1 -type d -name 'arch-system-recovery-*' \
        | head -1)"
    [[ -z "${extracted_dir}" ]] && die "Could not find extracted directory in tarball"

    # Install over current location
    log "Installing to ${REPO_ROOT}..."
    rsync -a --exclude='.git' "${extracted_dir}/" "${REPO_ROOT}/" \
        >> "${LOG_FILE}" 2>&1 \
        || die "rsync install failed. See log: ${LOG_FILE}"

    chmod +x "${REPO_ROOT}/bin/arch-recovery" \
              "${REPO_ROOT}/bin/arch-recovery.fish" \
              "${REPO_ROOT}/bin/arch-recovery.sh" \
              "${REPO_ROOT}/install.sh"

    rm -rf "${tmpdir}"
    _c_green; _c_bold
    printf "\n  ✓  Updated to %s. Restart arch-recovery to use the new version.\n\n" \
        "${latest_tag}" >&2
    _c_reset
    log "Self-update complete: ${current} → ${latest_tag}"
}

main "$@"
