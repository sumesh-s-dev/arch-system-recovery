#!/usr/bin/env bash
# bin/arch-recovery — Arch System Recovery Toolkit
# Works when called from bash, zsh, fish (arch-recovery.fish), sh (arch-recovery.sh)
# https://github.com/sumesh-s-dev/arch-system-recovery
set -euo pipefail

# ── Require Bash 4.2+ ─────────────────────────────────────────────────────────
if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 2) )); then
    echo "ERROR: arch-recovery requires Bash 4.2 or newer." >&2
    echo "       Your version: ${BASH_VERSION}" >&2
    exit 1
fi

# ── Locate repository root ────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
LIB_DIR="${REPO_ROOT}/lib"

# ── Load modules ──────────────────────────────────────────────────────────────
for _module in core ui tui detect luks mount repair preflight diagnose \
               fstab pacman network snapshot health; do
    # shellcheck source=/dev/null
    source "${LIB_DIR}/${_module}.sh" || {
        echo "ERROR: failed to load module: ${_module}.sh" >&2; exit 1
    }
done
unset _module

# ── Runtime defaults ──────────────────────────────────────────────────────────
AUTO_MODE=false
DRY_RUN=false
TUI_MODE=false
DIAGNOSE_MODE=false
ROOT_DEVICE=""
BOOT_DEVICE=""
EFI_DEVICE=""
LOG_LEVEL="normal"      # silent | normal | verbose | debug
DO_INITRAMFS=true
DO_BOOTLOADER=true
DO_FSTAB=true
DO_KEYRING=false
DO_NETWORK=false
LIST_SNAPSHOTS=false
SNAPSHOT_ROLLBACK=""
DO_HEALTH_CHECK=false
HEALTH_CHECK_ONLY=false
DO_UPDATE=false
CHECK_UPDATE_ONLY=false
ROOT_AUTO_DETECTED=false

# ── Safety trap ───────────────────────────────────────────────────────────────
_on_exit() {
    local code=$?
    [[ ${code} -eq 0 ]] || {
        declare -f err &>/dev/null \
            && err "Exiting with code ${code} — running cleanup..." \
            || echo "ERROR: Exiting with code ${code}" >&2
    }
    if declare -f cleanup_mounts &>/dev/null && [[ "${DRY_RUN}" != "true" ]]; then
        cleanup_mounts 2>/dev/null || true
    fi
}
trap '_on_exit' EXIT
trap 'echo ""; echo "Interrupted — cleaning up..."; exit 130' INT TERM

# ── Argument parser ───────────────────────────────────────────────────────────
parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --auto)            AUTO_MODE=true; HEALTH_CHECK_ONLY=false; shift ;;
            --dry-run)         DRY_RUN=true;                shift ;;
            --tui)             TUI_MODE=true; HEALTH_CHECK_ONLY=false; shift ;;
            --diagnose)        DIAGNOSE_MODE=true; HEALTH_CHECK_ONLY=false; shift ;;
            --root)            ROOT_DEVICE="${2:?--root requires a device}"; shift 2 ;;
            --boot)            BOOT_DEVICE="${2:?--boot requires a device}"; shift 2 ;;
            --efi)             EFI_DEVICE="${2:?--efi requires a device}";   shift 2 ;;
            --no-initramfs)    DO_INITRAMFS=false; HEALTH_CHECK_ONLY=false; shift ;;
            --no-bootloader)   DO_BOOTLOADER=false; HEALTH_CHECK_ONLY=false; shift ;;
            --no-fstab)        DO_FSTAB=false; HEALTH_CHECK_ONLY=false; shift ;;
            --repair-keyring)  DO_KEYRING=true; HEALTH_CHECK_ONLY=false; shift ;;
            --setup-network)   DO_NETWORK=true; HEALTH_CHECK_ONLY=false; shift ;;
            --list-snapshots)  LIST_SNAPSHOTS=true; HEALTH_CHECK_ONLY=false; shift ;;
            --rollback)        SNAPSHOT_ROLLBACK="${2:?--rollback requires a snapshot name}"; HEALTH_CHECK_ONLY=false; shift 2 ;;
            --log-level)
                case "${2:-}" in
                    silent|normal|verbose|debug) LOG_LEVEL="$2" ;;
                    *) die "Unknown log level '${2:-}'. Use: silent|normal|verbose|debug" ;;
                esac
                shift 2 ;;
            --verbose|-v)      LOG_LEVEL="verbose";         shift ;;
            --debug)           LOG_LEVEL="debug";           shift ;;
            --silent|-q)       LOG_LEVEL="silent";          shift ;;
            --help|-h)         _show_help;  exit 0 ;;
            --version)         echo "arch-recovery ${TOOLKIT_VERSION}"; exit 0 ;;
            --changelog)       _show_changelog; exit 0 ;;
            --health-check)    DO_HEALTH_CHECK=true; HEALTH_CHECK_ONLY=true; shift ;;
            --update)          DO_UPDATE=true; HEALTH_CHECK_ONLY=false; shift ;;
            --check-update)    CHECK_UPDATE_ONLY=true; HEALTH_CHECK_ONLY=false; shift ;;
            *)
                err "Unknown option: $1"
                echo "  Run: sudo arch-recovery --help" >&2
                exit 1 ;;
        esac
    done
}

_show_help() {
cat <<EOF

$(printf '\033[1m')arch-recovery v${TOOLKIT_VERSION}$(printf '\033[0m') — Arch Linux System Recovery Toolkit

$(printf '\033[1m')USAGE$(printf '\033[0m')
    sudo arch-recovery [OPTIONS]

$(printf '\033[1m')MODES$(printf '\033[0m')
    (none)              Guided interactive mode  ← safest for beginners
    --tui               Full-screen menu (whiptail/dialog or built-in fallback)
    --auto              Fully automated, no prompts
    --diagnose          Scan and report only — makes zero changes
    --dry-run           Simulate everything; nothing written to disk

$(printf '\033[1m')DEVICES$(printf '\033[0m')
    --root <dev>        Root partition  e.g. /dev/sda2  /dev/nvme0n1p2
    --boot <dev>        Separate /boot partition if present
    --efi  <dev>        EFI  partition  e.g. /dev/sda1  /dev/nvme0n1p1

$(printf '\033[1m')REPAIRS$(printf '\033[0m') (all on by default unless opted out)
    --no-initramfs      Skip mkinitcpio rebuild
    --no-bootloader     Skip bootloader reinstall
    --no-fstab          Skip fstab validation / repair
    --repair-keyring    Also repair pacman keyring + refresh mirrorlist
    --setup-network     Set up network first (WiFi or ethernet)

$(printf '\033[1m')BTRFS SNAPSHOTS$(printf '\033[0m')
    --list-snapshots    List BTRFS snapshots on root device
    --rollback <name>   Roll back to a named BTRFS snapshot

$(printf '\033[1m')POST-REPAIR$(printf '\033[0m')
    --health-check      Verify system is ready to boot (no changes)

$(printf '\033[1m')SELF-UPDATE$(printf '\033[0m')
    --update            Download and install latest release from GitHub
    --check-update      Check if a newer release exists (no install)

$(printf '\033[1m')VERBOSITY$(printf '\033[0m')
    --verbose / -v      Extra detail
    --debug             Trace every command
    --silent / -q       Errors only
    --log-level <lvl>   silent | normal | verbose | debug

$(printf '\033[1m')SHELL LAUNCHERS$(printf '\033[0m')
    arch-recovery           bash / zsh (default)
    arch-recovery.fish      fish shell
    arch-recovery.sh        POSIX sh / dash

$(printf '\033[1m')LOG$(printf '\033[0m')
    /tmp/arch-recovery-session.*/recovery-toolkit.log
    (actual path printed at startup)

$(printf '\033[1m')EXAMPLES$(printf '\033[0m')
    sudo arch-recovery                              # guided (beginner-friendly)
    sudo arch-recovery --tui                        # full-screen menu
    sudo arch-recovery --diagnose                   # what's broken?
    sudo arch-recovery --auto                       # fix everything automatically
    sudo arch-recovery --dry-run --verbose          # preview in full detail
    sudo arch-recovery --root /dev/sda2 --boot /dev/sda1 --efi /dev/sda3
    sudo arch-recovery --auto --repair-keyring
    sudo arch-recovery --list-snapshots --root /dev/sda2
    sudo arch-recovery --rollback @2024-01-15 --root /dev/sda2
    sudo arch-recovery --no-bootloader --repair-keyring --auto

EOF
}

_show_changelog() {
    cat <<'EOF'
CHANGELOG

v1.1.1
  + Added explicit --boot support for systems with a separate /boot partition
  + Strengthened root / boot / EFI auto-detection using mounted fstab ownership checks
  + Diagnose and health-check now mount separate /boot layouts read-only when needed
  + Self-update now installs only verified release bundles (.tar.gz + .sha256)
  + Added make dist for release bundle generation and checksum publication
  + TUI and CLI completion metadata updated for new flags
  + Fixed release bundle naming so published assets match the updater contract
  + Auto mode now fails fast instead of prompting when bootloader detection is unknown
  + Fixed the wpa_supplicant fallback temp-file path and tightened its temp-file permissions
  + Snapshot rollback now rejects unsafe snapshot names before touching the filesystem

v1.1.0
  + TUI full-screen menu (--tui) with whiptail/dialog, pure-bash fallback
  + Diagnose mode: colour-coded problem report, no changes (--diagnose)
  + Pre-flight checks: disk space, kernel presence, locale, missing hooks
  + fstab validator and auto-fixer (--no-fstab to skip)
  + Pacman keyring + mirrorlist repair (--repair-keyring)
  + Network setup from live USB: ethernet + nmcli WiFi (--setup-network)
  + BTRFS snapshot listing and rollback (--list-snapshots, --rollback)
  + Fish shell launcher: bin/arch-recovery.fish
  + POSIX sh launcher:   bin/arch-recovery.sh
  + Selective repair flags (--no-initramfs, --no-bootloader, --no-fstab)
  + Log levels: silent/normal/verbose/debug
  + LVM volume group detection and activation
  + Per-step rollback plan written to log before every destructive action
  + Colour-coded output with TTY detection (no colour when piped)

v1.0.0
  + Initial release
  + BTRFS / ext4, LUKS, GRUB (UEFI), systemd-boot
EOF
}

_fstab_expects_separate_boot() {
    local root="${1:-${MOUNT_ROOT}}"
    local boot_spec boot_dev boot_type boot_parttype

    boot_spec="$(_fstab_spec_for_mountpoint "${root}" "/boot" 2>/dev/null || true)"
    [[ -n "${boot_spec}" ]] || return 1

    boot_dev="$(resolve_device_spec "${boot_spec}")"
    [[ -n "${boot_dev}" ]] || return 0

    boot_type="$(blkid -s TYPE -o value "${boot_dev}" 2>/dev/null || true)"
    boot_parttype="$(blkid -s PART_ENTRY_TYPE -o value "${boot_dev}" 2>/dev/null || true)"

    [[ "${boot_type}" == "vfat" || \
       "${boot_parttype}" == "$(_efi_parttype_guid)" ]] && return 1
    return 0
}

_mount_boot_layout() {
    local mode="${1:-rw}"
    local strict_missing="${2:-true}"
    local allow_prompt="${3:-false}"
    local efi_mountpoint=""

    if [[ -z "${BOOT_DEVICE}" ]]; then
        BOOT_DEVICE="$(detect_boot_device "${MOUNT_ROOT}")"
        if [[ -z "${BOOT_DEVICE}" ]] && ${allow_prompt} && _fstab_expects_separate_boot "${MOUNT_ROOT}"; then
            BOOT_DEVICE="$(prompt_boot_device)"
        fi
    fi

    if [[ -n "${BOOT_DEVICE}" ]]; then
        mount_boot "${BOOT_DEVICE}" "${mode}"
        validate_mountpoint_device "${MOUNT_ROOT}" "/boot" "${BOOT_DEVICE}" "/boot device"
    elif ${strict_missing} && _fstab_expects_separate_boot "${MOUNT_ROOT}"; then
        die "The mounted system expects a separate /boot partition. Use --boot <device>."
    fi

    efi_mountpoint="$(detect_fstab_efi_mountpoint "${MOUNT_ROOT}")"
    if [[ -z "${EFI_DEVICE}" ]]; then
        EFI_DEVICE="$(auto_detect_efi "${MOUNT_ROOT}")"
        if [[ -z "${EFI_DEVICE}" && -n "${efi_mountpoint}" && ${allow_prompt} ]]; then
            EFI_DEVICE="$(prompt_efi_device)"
        fi
    fi

    if [[ -n "${EFI_DEVICE}" ]]; then
        mount_efi "${EFI_DEVICE}" "${mode}"
        [[ -n "${efi_mountpoint}" ]] && \
            validate_mountpoint_device "${MOUNT_ROOT}" "${efi_mountpoint}" "${EFI_DEVICE}" "EFI device"
    elif ${strict_missing} && [[ -n "${efi_mountpoint}" ]]; then
        die "The mounted system expects an EFI partition at ${efi_mountpoint}. Use --efi <device>."
    fi
}

# ── Main orchestration ────────────────────────────────────────────────────────
main() {
    parse_args "$@"

    init_log
    export LOG_LEVEL

    # Self-update / check-update
    if ${CHECK_UPDATE_ONLY}; then
        _check_for_update
        return 0
    fi
    if ${DO_UPDATE}; then
        _self_update
        return 0
    fi

    # Hand off to TUI immediately if requested
    if ${TUI_MODE}; then
        tui_main
        return 0
    fi

    print_banner
    check_root

    dlog "Repository root : ${REPO_ROOT}"
    dlog "Log level       : ${LOG_LEVEL}"
    dlog "Bash version    : ${BASH_VERSION}"

    # ── Standalone health check ───────────────────────────────────────────────
    if ${HEALTH_CHECK_ONLY}; then
        check_deps "readonly"
        run_standalone_health_check "${ROOT_DEVICE}" "${EFI_DEVICE}"
        return 0
    fi

    # ── Diagnose only ─────────────────────────────────────────────────────────
    if ${DIAGNOSE_MODE}; then
        check_deps "readonly"
        diagnose_main "${ROOT_DEVICE}" "${EFI_DEVICE}"
        return 0
    fi

    # ── Snapshot list ─────────────────────────────────────────────────────────
    if ${LIST_SNAPSHOTS}; then
        check_deps "readonly"
        [[ -z "${ROOT_DEVICE}" ]] && ROOT_DEVICE="$(
            ${AUTO_MODE} && auto_detect_root || prompt_root_device)"
        MAPPED_ROOT="${ROOT_DEVICE}"
        if is_luks "${ROOT_DEVICE}"; then
            log "LUKS detected on ${ROOT_DEVICE}"
            MAPPED_ROOT="$(unlock_luks "${ROOT_DEVICE}")"
        fi
        MAPPED_ROOT="$(detect_lvm "${MAPPED_ROOT}")"
        list_btrfs_snapshots "${MAPPED_ROOT}"
        return 0
    fi

    if [[ -n "${SNAPSHOT_ROLLBACK}" ]]; then
        check_deps "readonly"
    else
        check_deps
    fi

    # ── Network ───────────────────────────────────────────────────────────────
    if ${DO_NETWORK}; then
        print_step "NET" "Network setup"
        setup_network
    fi

    # ── Root partition ────────────────────────────────────────────────────────
    print_step "1" "Identify root partition"
    if [[ -z "${ROOT_DEVICE}" ]]; then
        ROOT_DEVICE="$(${AUTO_MODE} && auto_detect_root || prompt_root_device)"
        ROOT_AUTO_DETECTED=true
    else
        ROOT_AUTO_DETECTED=false
    fi
    log "Root device     : ${ROOT_DEVICE}"

    # ── LUKS ──────────────────────────────────────────────────────────────────
    print_step "2" "Encryption check"
    MAPPED_ROOT="${ROOT_DEVICE}"
    if is_luks "${ROOT_DEVICE}"; then
        log "LUKS detected on ${ROOT_DEVICE}"
        MAPPED_ROOT="$(unlock_luks "${ROOT_DEVICE}")"
    else
        log "No LUKS encryption on ${ROOT_DEVICE}"
    fi

    # ── LVM ───────────────────────────────────────────────────────────────────
    MAPPED_ROOT="$(detect_lvm "${MAPPED_ROOT}")"

    # ── Filesystem ───────────────────────────────────────────────────────────
    print_step "3" "Filesystem detection"
    FS_TYPE="$(detect_filesystem "${MAPPED_ROOT}")"

    # ── Snapshot rollback ─────────────────────────────────────────────────────
    if [[ -n "${SNAPSHOT_ROLLBACK}" ]]; then
        if ${DRY_RUN}; then
            log "[dry-run] Would roll back ${MAPPED_ROOT} to snapshot ${SNAPSHOT_ROLLBACK}"
            return 0
        fi
        if ! ${AUTO_MODE}; then
            confirm_snapshot_rollback "${ROOT_DEVICE}" "${MAPPED_ROOT}" "${SNAPSHOT_ROLLBACK}"
        fi
        _save_snapshot_rollback_plan "${ROOT_DEVICE}" "${MAPPED_ROOT}" "${SNAPSHOT_ROLLBACK}"
        rollback_snapshot "${MAPPED_ROOT}" "${SNAPSHOT_ROLLBACK}"
        return 0
    fi

    # ── Mount root ────────────────────────────────────────────────────────────
    print_step "4" "Mount root filesystem"
    if ${DRY_RUN}; then
        log "[dry-run] Would mount ${MAPPED_ROOT} (${FS_TYPE}) at ${MOUNT_ROOT}"
    else
        mount_root "${MAPPED_ROOT}" "${FS_TYPE}"
        validate_mounted_root "${MOUNT_ROOT}" "${MAPPED_ROOT}" "${ROOT_AUTO_DETECTED}"
    fi

    # ── /boot + EFI ───────────────────────────────────────────────────────────
    print_step "5" "Boot layout"
    if ${DRY_RUN}; then
        [[ -n "${BOOT_DEVICE}" ]] && log "[dry-run] Would mount /boot ${BOOT_DEVICE}"
        [[ -n "${EFI_DEVICE}" ]] && log "[dry-run] Would mount EFI ${EFI_DEVICE}"
    else
        if ${AUTO_MODE}; then
            _mount_boot_layout rw true false
        else
            _mount_boot_layout rw true true
        fi
    fi

    # ── Bootloader detection ─────────────────────────────────────────────────
    print_step "6" "Detect bootloader"
    BOOTLOADER="$(detect_bootloader)"

    # ── Pre-flight ────────────────────────────────────────────────────────────
    print_step "7" "Pre-flight checks"
    run_preflight "${MAPPED_ROOT}" "${EFI_DEVICE:-}" "${FS_TYPE}"

    # ── fstab validation ──────────────────────────────────────────────────────
    if ${DO_FSTAB} && ! ${DRY_RUN}; then
        print_step "8" "Validate /etc/fstab"
        validate_and_repair_fstab
    fi

    # ── Confirm before destructive steps ──────────────────────────────────────
    if ! ${AUTO_MODE} && ! ${DRY_RUN}; then
        confirm_repair \
            "${ROOT_DEVICE}" "${BOOT_DEVICE:-none}" "${EFI_DEVICE:-none}" \
            "${FS_TYPE}" "${BOOTLOADER}" "${DO_INITRAMFS}" \
            "${DO_BOOTLOADER}" "${DO_FSTAB}" "${DO_KEYRING}"
    fi

    # Save rollback plan to log before touching anything
    _save_rollback_plan "${ROOT_DEVICE}" "${BOOT_DEVICE:-}" "${EFI_DEVICE:-}" "${BOOTLOADER}"

    # ── Pacman keyring ────────────────────────────────────────────────────────
    if ${DO_KEYRING} && ! ${DRY_RUN}; then
        print_step "9" "Repair pacman keyring"
        repair_pacman_keyring
    fi

    # ── initramfs ─────────────────────────────────────────────────────────────
    if ${DO_INITRAMFS}; then
        print_step "10" "Rebuild initramfs"
        ${DRY_RUN} && log "[dry-run] arch-chroot mkinitcpio -P" \
                   || repair_initramfs
    fi

    # ── Bootloader ────────────────────────────────────────────────────────────
    if ${DO_BOOTLOADER}; then
        print_step "11" "Repair bootloader: ${BOOTLOADER}"
        ${DRY_RUN} && log "[dry-run] reinstall ${BOOTLOADER}" \
                   || repair_bootloader "${BOOTLOADER}" "${EFI_DEVICE:-}"
    fi

    # ── Post-repair health check ─────────────────────────────────────────────
    if ${DO_HEALTH_CHECK} && ! ${DRY_RUN}; then
        print_step "12" "Post-repair health check"
        run_health_check
    fi

    # ── Cleanup ───────────────────────────────────────────────────────────────
    ${DRY_RUN} || cleanup_mounts

    log "═══════════════════════════════════════════════"
    log " Recovery complete"
    log " Full log: ${LOG_FILE}"
    log "═══════════════════════════════════════════════"
    echo ""
    _c_green; _c_bold
    printf "  ✓  Recovery complete — safe to reboot.\n"
    _c_reset
    printf "     Full log: %s\n\n" "${LOG_FILE}"
}

# ── Save rollback plan ────────────────────────────────────────────────────────
_save_rollback_plan() {
    local root="$1" boot="${2:-}" efi="${3:-}" bl="${4:-}"
    {
        echo "═══ ROLLBACK PLAN (generated $(date)) ═══"
        echo "If this recovery made things worse, here is how to undo it manually:"
        echo ""
        echo "1. Boot the Arch live ISO again."
        echo "2. If LUKS: cryptsetup open ${root} recovery_crypt"
        echo "3. Mount root: mount ${root} /mnt"
        [[ -n "${boot}" ]] && echo "4. Mount /boot: mount ${boot} /mnt/boot"
        [[ -n "${efi}" ]] && echo "5. Mount EFI: mount ${efi} /mnt/boot/efi"
        echo "6. arch-chroot /mnt"
        echo "7. To redo initramfs: mkinitcpio -P"
        case "${bl}" in
            grub)
                echo "8. To redo GRUB: grub-install --target=x86_64-efi --efi-directory=/boot/efi"
                echo "                  grub-mkconfig -o /boot/grub/grub.cfg" ;;
            systemd-boot)
                echo "8. To redo systemd-boot: bootctl install" ;;
        esac
        echo "═══════════════════════════════════════════"
    } >> "${LOG_FILE}"
    dlog "Rollback plan saved to ${LOG_FILE}"
}

_save_snapshot_rollback_plan() {
    local root="$1" mapped_root="$2" snapshot="$3"
    {
        echo "═══ SNAPSHOT ROLLBACK PLAN (generated $(date)) ═══"
        echo "Target snapshot : ${snapshot}"
        echo "Mapped root     : ${mapped_root}"
        echo ""
        echo "If rollback fails or boots badly:"
        echo "1. Boot the Arch live ISO again."
        [[ "${root}" != "${mapped_root}" ]] && \
            echo "2. Re-open the original root container: ${root}"
        echo "3. Mount top-level BTRFS: mount -o subvolid=5 ${mapped_root} /mnt/top"
        echo "4. Rename ${snapshot} rollback target or restore the preserved @.broken-* subvolume."
        echo "5. Unmount: umount /mnt/top"
        echo "═══════════════════════════════════════════════════"
    } >> "${LOG_FILE}"
    dlog "Snapshot rollback plan saved to ${LOG_FILE}"
}

run_standalone_health_check() {
    local root_dev="${1:-}"
    local efi_dev="${2:-}"
    local mapped_root fstype

    print_step "HC1" "Identify root partition"
    if [[ -z "${root_dev}" ]]; then
        root_dev="$(auto_detect_root 2>/dev/null || prompt_root_device)"
    fi
    log "Health-check root device: ${root_dev}"

    mapped_root="${root_dev}"
    if is_luks "${root_dev}"; then
        log "LUKS detected on ${root_dev}"
        mapped_root="$(unlock_luks "${root_dev}")"
    fi
    mapped_root="$(detect_lvm "${mapped_root}")"

    print_step "HC2" "Filesystem detection"
    fstype="$(detect_filesystem "${mapped_root}")"

    print_step "HC3" "Mount root filesystem (read-only)"
    mount_root "${mapped_root}" "${fstype}" ro
    validate_mounted_root "${MOUNT_ROOT}" "${mapped_root}" true

    EFI_DEVICE="${efi_dev:-${EFI_DEVICE:-}}"
    print_step "HC4" "Mount boot layout (read-only)"
    _mount_boot_layout ro true true

    print_step "HC5" "Run health check"
    run_health_check
}

# ── Self-update helpers ───────────────────────────────────────────────────────

GITHUB_REPO="sumesh-s-dev/arch-system-recovery"
GITHUB_API="https://api.github.com/repos/${GITHUB_REPO}/releases/latest"
RELEASE_BUNDLE_PREFIX="arch-system-recovery"
RELEASE_SIGNING_NAMESPACE="arch-recovery"

_fetch_release_json() {
    command -v curl &>/dev/null || \
        die "Update checks require curl. Install it: pacman -S curl"
    curl -fsSL "${GITHUB_API}" 2>/dev/null || \
        die "Could not reach GitHub API. Check network connectivity."
}

_latest_release_tag() {
    local release_json="${1:?_latest_release_tag requires release JSON}"
    printf '%s\n' "${release_json}" \
        | grep '"tag_name"' \
        | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/' \
        | head -1
}

_release_bundle_name() {
    local tag="${1:?_release_bundle_name requires a tag}"
    echo "${RELEASE_BUNDLE_PREFIX}-${tag}.tar.gz"
}

_release_bundle_checksum_name() {
    local tag="${1:?_release_bundle_checksum_name requires a tag}"
    echo "$(_release_bundle_name "${tag}").sha256"
}

_release_bundle_manifest_name() {
    local tag="${1:?_release_bundle_manifest_name requires a tag}"
    echo "${RELEASE_BUNDLE_PREFIX}-${tag}.manifest"
}

_release_bundle_manifest_signature_name() {
    local tag="${1:?_release_bundle_manifest_signature_name requires a tag}"
    echo "$(_release_bundle_manifest_name "${tag}").sig"
}

_release_asset_url() {
    local release_json="${1:?_release_asset_url requires release JSON}"
    local asset_name="${2:?_release_asset_url requires an asset name}"

    printf '%s\n' "${release_json}" | awk -v asset="${asset_name}" '
        $0 ~ "\"name\": \"" asset "\"" {found=1; next}
        found && /"browser_download_url":/ {
            gsub(/.*"browser_download_url": *"/, "", $0)
            gsub(/".*/, "", $0)
            print
            exit
        }
    '
}

_is_source_checkout() {
    [[ "${LIB_DIR}" == "${REPO_ROOT}/lib" ]] && \
        [[ -d "${REPO_ROOT}/lib" ]] && [[ -f "${REPO_ROOT}/README.md" ]]
}

_release_signers_file() {
    if [[ -n "${RELEASE_SIGNERS_FILE:-}" ]]; then
        echo "${RELEASE_SIGNERS_FILE}"
        return 0
    fi

    if [[ -f "${REPO_ROOT}/keys/release_signers.allowed" ]]; then
        echo "${REPO_ROOT}/keys/release_signers.allowed"
        return 0
    fi

    if [[ -f "${REPO_ROOT}/share/doc/arch-recovery/keys/release_signers.allowed" ]]; then
        echo "${REPO_ROOT}/share/doc/arch-recovery/keys/release_signers.allowed"
        return 0
    fi

    return 1
}

_release_signer_principal() {
    if [[ -n "${RELEASE_SIGNER_PRINCIPAL:-}" ]]; then
        echo "${RELEASE_SIGNER_PRINCIPAL}"
        return 0
    fi

    awk 'NF >= 2 {print $1; exit}' "$(_release_signers_file)"
}

_verify_release_manifest_signature() {
    local manifest_path="${1:?_verify_release_manifest_signature requires a manifest path}"
    local signature_path="${2:?_verify_release_manifest_signature requires a signature path}"
    local signers principal

    command -v ssh-keygen &>/dev/null || die "Signed release verification requires ssh-keygen."
    signers="$(_release_signers_file)" || die "Signed release verification requires release_signers.allowed."
    principal="$(_release_signer_principal)" || die "Could not determine the trusted release signer principal."

    ssh-keygen -Y verify \
        -f "${signers}" \
        -I "${principal}" \
        -n "${RELEASE_SIGNING_NAMESPACE}" \
        -s "${signature_path}" \
        < "${manifest_path}" \
        >> "${LOG_FILE}" 2>&1 \
        || die "Release manifest signature verification failed."
}

_assert_clean_source_checkout() {
    _is_source_checkout || return 0
    command -v git &>/dev/null || die "Source checkout updates require git metadata and the git CLI."
    git -C "${REPO_ROOT}" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
        || die "Source checkout updates require a real git working tree."
    [[ -z "$(git -C "${REPO_ROOT}" status --porcelain 2>/dev/null || true)" ]] \
        || die "Refusing to self-update with uncommitted changes in the source checkout."
}

_download_verified_release_bundle() {
    local release_json="${1:?_download_verified_release_bundle requires release JSON}"
    local tag="${2:?_download_verified_release_bundle requires a tag}"
    local tmpdir="${3:?_download_verified_release_bundle requires a temp dir}"
    local archive_name checksum_name manifest_name signature_name
    local archive_url checksum_url manifest_url signature_url

    archive_name="$(_release_bundle_name "${tag}")"
    checksum_name="$(_release_bundle_checksum_name "${tag}")"
    manifest_name="$(_release_bundle_manifest_name "${tag}")"
    signature_name="$(_release_bundle_manifest_signature_name "${tag}")"
    archive_url="$(_release_asset_url "${release_json}" "${archive_name}")"
    checksum_url="$(_release_asset_url "${release_json}" "${checksum_name}")"
    manifest_url="$(_release_asset_url "${release_json}" "${manifest_name}")"
    signature_url="$(_release_asset_url "${release_json}" "${signature_name}")"

    [[ -n "${archive_url}" && -n "${checksum_url}" ]] || \
        die "Release ${tag} is missing verified update assets (${archive_name} and ${checksum_name})."

    command -v tar &>/dev/null || die "Verified updates require tar."
    command -v sha256sum &>/dev/null || die "Verified updates require sha256sum."

    log "Downloading verified update bundle ${archive_name}..."
    curl -fsSL "${archive_url}" -o "${tmpdir}/${archive_name}" \
        || die "Failed to download ${archive_name}"
    curl -fsSL "${checksum_url}" -o "${tmpdir}/${checksum_name}" \
        || die "Failed to download ${checksum_name}"

    if [[ -n "${manifest_url}" && -n "${signature_url}" ]]; then
        curl -fsSL "${manifest_url}" -o "${tmpdir}/${manifest_name}" \
            || die "Failed to download ${manifest_name}"
        curl -fsSL "${signature_url}" -o "${tmpdir}/${signature_name}" \
            || die "Failed to download ${signature_name}"
        _verify_release_manifest_signature "${tmpdir}/${manifest_name}" "${tmpdir}/${signature_name}"
        cmp -s "${tmpdir}/${manifest_name}" "${tmpdir}/${checksum_name}" \
            || die "Signed manifest does not match ${checksum_name}"
        (cd "${tmpdir}" && sha256sum -c "${manifest_name}") >> "${LOG_FILE}" 2>&1 \
            || die "Signed manifest verification failed for ${archive_name}"
    else
        warn "Release ${tag} does not include signed manifest assets; falling back to checksum-only verification."
        (cd "${tmpdir}" && sha256sum -c "${checksum_name}") >> "${LOG_FILE}" 2>&1 \
            || die "Checksum verification failed for ${archive_name}"
    fi

    echo "${tmpdir}/${archive_name}"
}

_extract_verified_release_bundle() {
    local archive_path="${1:?_extract_verified_release_bundle requires an archive}"
    local tag="${2:?_extract_verified_release_bundle requires a tag}"
    local tmpdir="${3:?_extract_verified_release_bundle requires a temp dir}"
    local extracted_dir version

    tar -xzf "${archive_path}" -C "${tmpdir}" \
        || die "Failed to extract verified update bundle"

    extracted_dir="$(find "${tmpdir}" -maxdepth 1 -type d -name 'arch-system-recovery-*' \
        | head -1)"
    [[ -n "${extracted_dir}" ]] || die "Could not find extracted directory in verified update bundle"
    [[ -f "${extracted_dir}/lib/core.sh" ]] || die "Verified update bundle is missing lib/core.sh"

    version="$(sed -n 's/^.*TOOLKIT_VERSION="\([^"]*\)".*/\1/p' "${extracted_dir}/lib/core.sh" \
        | head -1)"
    [[ "v${version}" == "${tag}" ]] || \
        die "Verified update bundle version (${version:-unknown}) does not match release tag ${tag}"

    echo "${extracted_dir}"
}

_install_verified_release_bundle() {
    local extracted_dir="${1:?_install_verified_release_bundle requires a directory}"

    if _is_source_checkout; then
        _assert_clean_source_checkout
        command -v rsync &>/dev/null || die "Source checkout updates require rsync."
        [[ -w "${REPO_ROOT}" ]] || die "Source checkout is not writable: ${REPO_ROOT}"
        log "Installing verified update into source checkout ${REPO_ROOT}..."
        rsync -a --exclude='.git' "${extracted_dir}/" "${REPO_ROOT}/" \
            >> "${LOG_FILE}" 2>&1 \
            || die "Verified source checkout update failed. See log: ${LOG_FILE}"
    else
        check_root
        [[ -x "${extracted_dir}/install.sh" ]] || die "Verified update bundle is missing install.sh"
        log "Installing verified update into prefix ${REPO_ROOT}..."
        bash "${extracted_dir}/install.sh" --prefix "${REPO_ROOT}" \
            >> "${LOG_FILE}" 2>&1 \
            || die "Verified prefix install failed. See log: ${LOG_FILE}"
    fi
}

_check_for_update() {
    log "Checking for updates..."
    local release_json latest_tag
    release_json="$(_fetch_release_json)"
    latest_tag="$(_latest_release_tag "${release_json}")"

    if [[ -z "${latest_tag}" ]]; then
        warn "Could not determine latest release tag."
        return 1
    fi

    local current="v${TOOLKIT_VERSION}"
    log "Current version : ${current}"
    log "Latest release  : ${latest_tag}"

    if [[ "${current}" == "${latest_tag}" ]]; then
        _c_green; printf "\n  ✓  arch-recovery is up to date (%s)\n\n" "${current}" >&2
        _c_reset
    else
        _c_yellow; _c_bold
        printf "\n  ↑  Update available: %s → %s\n" "${current}" "${latest_tag}" >&2
        _c_reset
        printf "     Run: sudo arch-recovery --update\n\n" >&2
    fi
}

_self_update() {
    local release_json latest_tag current tmpdir archive_path extracted_dir

    release_json="$(_fetch_release_json)"
    latest_tag="$(_latest_release_tag "${release_json}")"
    [[ -n "${latest_tag}" ]] || die "Could not determine latest release tag."

    current="v${TOOLKIT_VERSION}"
    log "Current version : ${current}"
    log "Latest release  : ${latest_tag}"

    [[ "${current}" == "${latest_tag}" ]] && {
        echo "  Already at latest version (${current})." >&2
        return 0
    }

    tmpdir="$(_make_private_temp_dir "arch-recovery-update")"
    archive_path="$(_download_verified_release_bundle "${release_json}" "${latest_tag}" "${tmpdir}")"
    extracted_dir="$(_extract_verified_release_bundle "${archive_path}" "${latest_tag}" "${tmpdir}")"
    _install_verified_release_bundle "${extracted_dir}"

    rm -rf "${tmpdir}"
    _c_green; _c_bold
    printf "\n  ✓  Updated to %s. Restart arch-recovery to use the new version.\n\n" \
        "${latest_tag}" >&2
    _c_reset
    log "Self-update complete: ${current} → ${latest_tag}"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
